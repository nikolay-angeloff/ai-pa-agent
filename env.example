# Copy to .env and fill in. NEVER commit .env (add it to .gitignore).

# --- Postgres ---
POSTGRES_USER=expense
POSTGRES_PASSWORD=change_me
POSTGRES_DB=expense

# --- LLM (local: API keys; AWS uses Bedrock instead, no keys) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Observability (optional) ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true

# --- Auth ---
JWT_SECRET=change_me_to_a_long_random_string

# --- Cockpit channels ---
TELEGRAM_BOT_TOKEN=
VIBER_AUTH_TOKEN=          # optional; requires a Viber public account + HTTPS webhook

# --- Gmail ingestion (Phase 1) ---
# Use OAuth client credentials; store the token securely. Fill when you reach Phase 1.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
