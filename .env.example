# Copy this file to .env and fill in the values.
# NEVER commit .env — it is in .gitignore.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=expense
POSTGRES_PASSWORD=changeme
POSTGRES_DB=expense

# ── LLM (local dev — API keys; AWS profile uses Bedrock instead) ──────────────
OPENAI_API_KEY=sk-...          # used by facade for embeddings (text-embedding-3-small)
                                # and by agents (classify=gpt-5.4-nano, extract/query=gpt-5.5)
ANTHROPIC_API_KEY=sk-ant-...   # unused for now — kept for an easy provider swap back

# ── LangSmith — optional but recommended (free tier available) ────────────────
# Sign up at https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=expense-agent   # organises all runs under one project in the UI

# ── Gateway auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── VPS deploy only (docker-compose.prod.yml) — unused for local dev ──────────
DOMAIN=                      # public domain pointed at the VPS, e.g. expenses.example.com
ACME_EMAIL=                  # your email — Let's Encrypt sends cert-expiry/problem notices here

# ── Cockpit channels (Phase 3) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # create via @BotFather on Telegram
TELEGRAM_CHAT_ID=            # numeric chat.id to push scheduled insights to; find it in webhook logs
                              # ([telegram] normalized update: { userId: ... }) after messaging your bot once
TELEGRAM_WEBHOOK_SECRET=     # optional; random string, verifies incoming webhook calls are really from Telegram
VIBER_AUTH_TOKEN=             # optional; needs public account + HTTPS
EVENTS_SECRET=               # optional; shared secret for facade -> webhook internal event calls (Phase 4 WS prep)
INSIGHT_CRON=                # optional; overrides the default daily 08:00 anomaly-scan schedule (cron syntax)

# ── Gmail ingestion (Phase 1) ─────────────────────────────────────────────────
# Create an OAuth 2.0 client in Google Cloud Console (Gmail API).
# Run scripts/get_gmail_token.py to obtain the refresh token.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
